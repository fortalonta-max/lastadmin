# Copy to `.env` at the project root and fill in your values.
# Vite exposes only variables prefixed with VITE_ to client code.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Your custom domain (no trailing slash). Used to generate absolute og:url tags so
# social crawlers (Instagram, Facebook, WhatsApp, Telegram, X/Twitter, LinkedIn)
# correctly identify and cache the preview image for your domain.
# Example: https://www.leenbakery.com
VITE_SITE_URL=https://your-custom-domain.com

# Optional: override the og:image used on the homepage.
# Must be an absolute URL to a publicly accessible image (1200×630 px recommended).
# If left empty the hero image from Supabase settings is used, falling back to the
# default preview image defined in src/routes/__root.tsx.
VITE_OG_IMAGE_URL=
